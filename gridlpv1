:#6b7480;\n    --green:#00C48C;\n    --green-2:#00d99c;\n    --green-soft:rgba(0,196,140,.12);\n    --green-softer:rgba(0,196,140,.06);\n    --light-bg:#ffffff;\n    --light-panel:#fafbfc;\n    --light-line:#e6e8ec;\n    --light-text:#0D1117;\n    --light-muted:#5b6470;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;padding:0}\n  body{\n    font-family:'Inter',system-ui,-apple-system,sans-serif;\n    background:var(--bg);\n    color:var(--text);\n    -webkit-font-smoothing:antialiased;\n    text-rendering:optimizeLegibility;\n    line-height:1.5;\n  }\n  a{color:inherit;text-decoration:none}\n  img{max-width:100%;display:block}\n  .container{max-width:1200px;margin:0 auto;padding:0 32px}\n\n  /* ====================== NAV ====================== */\n  header.nav{\n    position:relative;z-index:5;\n    padding:22px 0;\n  }\n  .nav-inner{display:flex;align-items:center;justify-content:space-between;gap:24px}\n  .logo{\n    display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.02em;font-size:18px;\n  }\n  .logo-mark{\n    width:32px;height:32px;border-radius:8px;\n    background:#000 center/contain no-repeat url(\"a17ab967-86c0-41ca-80a5-6086f8c05e27\");\n    box-shadow:0 0 0 1px rgba(255,255,255,.08), 0 6px 18px -6px rgba(0,0,0,.5);\n    flex:0 0 auto;\n  }\n  .logo-beta{\n    font-size:10px;font-weight:600;letter-spacing:.12em;\n    padding:3px 8px;border-radius:999px;\n    border:1px solid rgba(0,196,140,.4);color:var(--green);\n    background:var(--green-softer);\n  }\n  .nav-right{display:flex;align-items:center;gap:28px;font-size:13.5px;color:#cdd2d8}\n  .nav-right .item{display:flex;align-items:center;gap:8px}\n  .nav-right .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 0 3px rgba(0,196,140,.18)}\n  .nav-right .ico-wa{\n    width:18px;height:18px;border-radius:50%;background:var(--green);display:inline-grid;place-items:center;\n  }\n  .nav-right .ico-wa svg{width:11px;height:11px;color:#0D1117}\n\n  /* ====================== HERO ====================== */\n  .hero{\n    position:relative;\n    padding:32px 0 60px;\n    overflow:hidden;\n  }\n  .hero::before{\n    content:\"\";position:absolute;inset:-200px -100px auto auto;width:900px;height:900px;\n    background:radial-gradient(closest-side, rgba(0,196,140,.16), rgba(0,196,140,0) 70%);\n    pointer-events:none;filter:blur(10px);\n  }\n  .hero::after{\n    content:\"\";position:absolute;inset:0;\n    background-image:\n      linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);\n    background-size:48px 48px;\n    mask-image:radial-gradient(ellipse at 30% 40%, #000 30%, transparent 75%);\n    pointer-events:none;\n  }\n  .hero-grid{\n    position:relative;z-index:1;\n    display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:center;\n  }\n  .eyebrow{\n    display:inline-flex;align-items:center;gap:8px;\n    padding:7px 14px;border-radius:999px;\n    border:1px solid rgba(0,196,140,.4);\n    background:var(--green-softer);\n    color:var(--green);font-size:12px;font-weight:600;letter-spacing:.06em;\n    text-transform:uppercase;\n  }\n  .eyebrow::before{content:\"\";width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 0 4px rgba(0,196,140,.18)}\n  h1.hero-title{\n    font-size:clamp(38px, 4.8vw, 60px);\n    line-height:1.04;letter-spacing:-.025em;\n    font-weight:800;\n    margin:22px 0 18px;\n    text-wrap:balance;\n  }\n  h1.hero-title .accent{color:var(--green);position:relative;white-space:nowrap}\n  h1.hero-title .accent::after{\n    content:\"\";position:absolute;left:0;right:0;bottom:-2px;height:2px;\n    background:linear-gradient(90deg, transparent, var(--green), transparent);\n    opacity:.5;\n  }\n  .lede{color:#bcc3cb;font-size:17px;max-width:520px;margin:0 0 28px}\n  .badges{display:flex;flex-wrap:wrap;gap:18px 28px;margin:0 0 36px}\n  .badge{display:flex;align-items:flex-start;gap:10px;max-width:170px}\n  .badge .b-ico{\n    flex:0 0 auto;width:30px;height:30px;border-radius:8px;\n    background:var(--green-soft);display:grid;place-items:center;color:var(--green);\n    border:1px solid rgba(0,196,140,.25);\n  }\n  .badge .b-ico svg{width:15px;height:15px}\n  .badge .b-text{font-size:13.5px;font-weight:600;color:#e6eaee;line-height:1.25}\n\n  .cta-row{display:flex;flex-direction:column;align-items:flex-start;gap:14px}\n  .cta-buttons{display:flex;flex-wrap:wrap;gap:12px;align-items:center}\n  .btn-cta{\n    display:inline-flex;align-items:center;justify-content:center;gap:12px;\n    padding:17px 28px;border-radius:14px;\n    background:linear-gradient(180deg, var(--green-2), var(--green));\n    color:#062118;font-weight:700;font-size:16px;\n    border:none;cursor:pointer;white-space:nowrap;\n    box-shadow:\n      0 0 0 1px rgba(0,196,140,.5),\n      0 14px 30px -10px rgba(0,196,140,.55),\n      inset 0 1px 0 rgba(255,255,255,.35);\n    transition:transform .15s ease, box-shadow .2s ease;\n  }\n  .btn-cta:hover{transform:translateY(-1px);box-shadow:0 0 0 1px rgba(0,196,140,.6),0 18px 36px -10px rgba(0,196,140,.7),inset 0 1px 0 rgba(255,255,255,.4)}\n  .btn-cta .wa-ico{width:24px;height:24px;border-radius:50%;background:rgba(6,33,24,.18);display:grid;place-items:center}\n  .btn-cta .wa-ico svg{width:13px;height:13px}\n  .btn-ghost{\n    display:inline-flex;align-items:center;justify-content:center;gap:10px;\n    padding:16px 24px;border-radius:14px;\n    background:transparent;color:#fff;font-weight:600;font-size:15.5px;\n    border:1px solid rgba(255,255,255,.18);cursor:pointer;white-space:nowrap;\n    transition:background .15s ease, border-color .2s ease, transform .15s ease;\n  }\n  .btn-ghost:hover{background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.32);transform:translateY(-1px)}\n  .btn-ghost .play{\n    width:22px;height:22px;border-radius:50%;background:rgba(0,196,140,.16);border:1px solid rgba(0,196,140,.4);\n    display:grid;place-items:center;color:var(--green);\n  }\n  .btn-ghost .play svg{width:9px;height:9px;margin-left:1px}\n  .clock{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:13px;padding-left:6px}\n  .clock svg{width:14px;height:14px;opacity:.8}\n\n  .social-proof{\n    display:flex;align-items:center;gap:14px;margin-top:34px;\n  }\n  .avatars{display:flex}\n  .avatars img{\n    width:36px;height:36px;border-radius:50%;border:2px solid var(--bg);\n    object-fit:cover;margin-left:-10px;background:#222;\n  }\n  .avatars img:first-child{margin-left:0}\n  .sp-text{font-size:13.5px;color:#cdd2d8;line-height:1.35}\n  .sp-text b{color:#fff;font-weight:600}\n\n  /* ====================== PHONE ====================== */\n  .phone-stage{\n    position:relative;display:flex;justify-content:center;align-items:flex-start;\n    padding-top:6px;\n  }\n  .phone{\n    --phw: 320px;\n    --phh: 660px;\n    width:var(--phw);height:var(--phh);\n    border-radius:48px;\n    background:#0a0e13;\n    padding:8px;\n    box-shadow:\n      inset 0 0 0 2px #2a313a,\n      0 0 0 1px #1a1f27,\n      0 30px 60px -20px rgba(0,0,0,.7),\n      0 60px 120px -30px rgba(0,196,140,.18);\n    position:relative;\n  }\n  .phone-screen{\n    width:100%;height:100%;border-radius:42px;overflow:hidden;\n    background:#0b141a;display:flex;flex-direction:column;\n    position:relative;\n  }\n  .phone-screen--img{display:block}\n  .phone-screen--img img{\n    width:100%;height:100%;object-fit:cover;object-position:center bottom;display:block;\n  }\n  .notch{\n    position:absolute;left:50%;top:10px;transform:translateX(-50%);\n    width:100px;height:28px;border-radius:18px;background:#000;z-index:5;\n  }\n  .notch::before,.notch::after{\n    content:\"\";position:absolute;top:50%;transform:translateY(-50%);border-radius:50%;background:#1a1f27;\n  }\n  .notch::before{left:10px;width:6px;height:6px;background:#0d2538}\n  .notch::after{right:14px;width:3px;height:3px}\n  .status{\n    display:
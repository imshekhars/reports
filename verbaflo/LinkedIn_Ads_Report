<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VerbaFlo — LinkedIn Ads Performance Report | Dec 2025–Apr 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#0D0F0C;--paper:#F5F3EE;--paper-dark:#EAE7E0;--accent:#1B4D3E;--al:rgba(27,77,62,0.1);--gold:#C8922A;--blue:#185FA5;--red:#C0392B;--purple:#534AB7;--amber:#BA7517;--teal:#0F6E56;--text:#1A1C19;--muted:#6B6D68;--light:#9B9D98;--border:rgba(0,0,0,0.07);}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--text);line-height:1.6}
header{background:linear-gradient(135deg,#0A3B6E 0%,#061F3A 100%);padding:40px 48px;position:relative;overflow:hidden}
header::after{content:'';position:absolute;right:-80px;top:-80px;width:360px;height:360px;border-radius:50%;background:rgba(200,146,42,0.1)}
.header-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1}
.header-label{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,0.45);margin-bottom:8px}
header h1{font-family:'Fraunces',serif;font-size:32px;font-weight:800;color:white;letter-spacing:-1px;line-height:1.1;margin-bottom:6px}
header p{font-size:14px;color:rgba(255,255,255,0.55);font-weight:300}
.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:5px 14px;font-size:12px;color:rgba(255,255,255,0.8);margin-top:14px}
.container{max-width:1200px;margin:0 auto;padding:40px 48px}
.sg{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:40px}
.sc{background:white;border:1px solid var(--border);border-radius:12px;padding:16px 18px}
.sl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--light);margin-bottom:4px}
.sv{font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--ink);line-height:1}
.ss{font-size:11px;margin-top:3px}
.up{color:#3B6D11}.dn{color:var(--red)}.neu{color:var(--muted)}
.block{margin-bottom:48px}
.bt{font-family:'Fraunces',serif;font-size:18px;font-weight:700;color:var(--ink);letter-spacing:-0.3px;margin-bottom:4px}
.bs{font-size:13px;color:var(--muted);margin-bottom:20px;font-weight:300}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
.cc{background:white;border:1px solid var(--border);border-radius:12px;padding:24px}
.cc.full{grid-column:1/-1}
.cl{font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:12px}
.cw{position:relative;width:100%}
.h280{height:280px}.h220{height:220px}.h200{height:200px}
.lr{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:10px}
.leg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.ld{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.tw{background:white;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-top:16px}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{background:#0A3B6E}
thead th{color:white;padding:10px 14px;text-align:left;font-size:11px;font-weight:500}
tbody tr:nth-child(even){background:#F9F9F8}
tbody tr:hover{background:var(--al)}
tbody td{padding:9px 14px;border-bottom:1px solid var(--border);color:var(--text)}
.pill{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:500}
.pg{background:#E8F5E9;color:#2E7D32}.pr{background:#FFEBEE;color:#C62828}.pa{background:#FFF8E1;color:#F57F17}.pb{background:#E3F2FD;color:#1565C0}
.ig{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:20px}
.ic{background:white;border:1px solid var(--border);border-radius:12px;padding:20px 22px}
.il{font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.ib{font-size:13px;color:var(--muted);line-height:1.6;font-weight:300}
hr.div{border:none;border-top:1px solid var(--border);margin:40px 0}
footer{background:var(--ink);padding:24px 48px;display:flex;justify-content:space-between;align-items:center}
footer span{font-size:12px;color:rgba(255,255,255,0.3)}
.fl{font-family:'Fraunces',serif;font-weight:700;font-size:16px;color:white}
.fl span{color:var(--gold)}
@media(max-width:900px){.sg,.g2,.g3,.ig{grid-template-columns:1fr 1fr}.container{padding:24px}header{padding:28px 24px}}
@media(max-width:600px){.sg,.ig{grid-template-columns:1fr}}
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="header-label">Performance Report</div>
    <h1>VerbaFlo — LinkedIn Ads Analysis</h1>
    <p>December 2025 — April 2026 &nbsp;·&nbsp; UK, US, UAE &nbsp;·&nbsp; Engagement, Message, Lead Gen</p>
    <div class="badge">💼 LinkedIn Campaign Manager</div>
  </div>
</header>

<div class="container">
  <div class="sg" style="margin-top:32px">
    <div class="sc"><div class="sl">Total spend</div><div class="sv">$5,747</div><div class="ss neu">Dec 25 – Apr 26</div></div>
    <div class="sc"><div class="sl">Total impressions</div><div class="sv">151k+</div><div class="ss up">↑ Peaked Jan at 50k</div></div>
    <div class="sc"><div class="sl">Total clicks</div><div class="sv">3,041</div><div class="ss neu">Across all campaigns</div></div>
    <div class="sc"><div class="sl">Total engagements</div><div class="sv">9,350</div><div class="ss up">↑ Growing MoM</div></div>
    <div class="sc"><div class="sl">Message opens</div><div class="sv">3,269</div><div class="ss neu">52–54% open rates</div></div>
    <div class="sc"><div class="sl">Total leads</div><div class="sv">6</div><div class="ss neu">From message campaigns</div></div>
  </div>

  <!-- SECTION 1: OVERALL -->
  <section class="block">
    <div class="bt">Overall Monthly Performance Trends</div>
    <div class="bs">Total spend, impressions, clicks and engagements — December 2025 to April 2026</div>
    <div class="g2">
      <div class="cc">
        <div class="cl">Monthly Spend ($)</div>
        <div class="cw h280"><canvas id="spendLine"></canvas></div>
      </div>
      <div class="cc">
        <div class="lr">
          <div class="leg"><span class="ld" style="background:#185FA5"></span>Impressions</div>
          <div class="leg"><span class="ld" style="background:#C8922A"></span>Engagements</div>
        </div>
        <div class="cl">Impressions & Engagements MoM</div>
        <div class="cw h280"><canvas id="impEng"></canvas></div>
      </div>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 2: CAMPAIGN MIX -->
  <section class="block">
    <div class="bt">Campaign Type Breakdown</div>
    <div class="bs">LinkedIn was run across two formats — Sponsored Updates (engagement/traffic) and Sponsored Messaging (direct outreach). Here's how each performed.</div>
    <div class="g2">
      <div class="cc">
        <div class="lr">
          <div class="leg"><span class="ld" style="background:#1B4D3E"></span>Engagement / Sponsored Update</div>
          <div class="leg"><span class="ld" style="background:#185FA5"></span>Message / Lead Gen</div>
        </div>
        <div class="cl">Spend by Campaign Type — Stacked ($)</div>
        <div class="cw h280"><canvas id="typeStack"></canvas></div>
      </div>
      <div class="cc">
        <div class="cl">CPM Trend ($) — Cost per 1,000 Impressions</div>
        <div class="cw h280"><canvas id="cpmLine"></canvas></div>
      </div>
    </div>

    <div class="tw">
      <table>
        <thead><tr><th>Month</th><th>Total Spend</th><th>Impressions</th><th>Clicks</th><th>CTR</th><th>Engagements</th><th>CPM</th><th>Leads</th><th>MoM Spend</th></tr></thead>
        <tbody>
          <tr><td>Dec 2025</td><td>$434</td><td>39,657</td><td>358</td><td>0.90%</td><td>361</td><td>$10.96</td><td><span class="pill pr">0</span></td><td>—</td></tr>
          <tr><td>Jan 2026</td><td>$961</td><td>50,103</td><td>509</td><td>1.02%</td><td>1,816</td><td>$19.19</td><td><span class="pill pg">3</span></td><td><span class="pill pa">+121%</span></td></tr>
          <tr><td>Feb 2026</td><td>$1,751</td><td>23,079</td><td>1,005</td><td>4.35%</td><td>2,237</td><td>$75.87</td><td><span class="pill pg">2</span></td><td><span class="pill pa">+82%</span></td></tr>
          <tr><td>Mar 2026</td><td>$1,643</td><td>29,068</td><td>1,061</td><td>3.65%</td><td>3,138</td><td>$56.52</td><td><span class="pill pr">0</span></td><td><span class="pill pg">−6%</span></td></tr>
          <tr><td>Apr 2026</td><td>$958</td><td>10,022</td><td>108</td><td>1.08%</td><td>238</td><td>$95.56</td><td><span class="pill pg">1</span></td><td><span class="pill pr">−42%</span></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 3: MESSAGE CAMPAIGNS -->
  <section class="block">
    <div class="bt">Message Campaign Deep-dive</div>
    <div class="bs">LinkedIn message ads achieved 52–54% open rates throughout — well above the 35% industry average. The challenge was converting those opens into lead form completions.</div>
    <div class="g2">
      <div class="cc">
        <div class="lr">
          <div class="leg"><span class="ld" style="background:#1B4D3E"></span>Sends</div>
          <div class="leg"><span class="ld" style="background:#C8922A"></span>Opens</div>
        </div>
        <div class="cl">Message Sends vs Opens MoM</div>
        <div class="cw h280"><canvas id="msgBar"></canvas></div>
      </div>
      <div class="cc">
        <div class="cl">Open Rate Trend — Message Campaigns</div>
        <div class="cw h280"><canvas id="openRate"></canvas></div>
      </div>
    </div>

    <div class="tw" style="margin-top:20px">
      <table>
        <thead><tr><th>Campaign</th><th>Month</th><th>Spend</th><th>Sends</th><th>Opens</th><th>Open Rate</th><th>Leads</th><th>CPL</th><th>Status</th></tr></thead>
        <tbody>
          <tr><td>Lead-Messaging (US)</td><td>Jan 26</td><td>$343</td><td>4,345</td><td>1,107</td><td>25.5%</td><td><span class="pill pg">3</span></td><td>$114</td><td><span class="pill pg">Converted</span></td></tr>
          <tr><td>Messaging Lead (US)</td><td>Feb 26</td><td>$108</td><td>852</td><td>385</td><td>45.2%</td><td><span class="pill pr">0</span></td><td>—</td><td><span class="pill pr">Paused</span></td></tr>
          <tr><td>Lead-Messaging (US)</td><td>Feb 26</td><td>$347</td><td>253</td><td>420</td><td>52.0%</td><td><span class="pill pg">1</span></td><td>$347</td><td><span class="pill pa">Paused</span></td></tr>
          <tr><td>Lead-Messaging (US)</td><td>Mar 26</td><td>$194</td><td>62</td><td>32</td><td>51.6%</td><td><span class="pill pr">0</span></td><td>—</td><td><span class="pill pr">Paused</span></td></tr>
          <tr><td>Message Leads (UK)</td><td>Mar 26</td><td>$160</td><td>2,440</td><td>1,314</td><td>53.9%</td><td><span class="pill pr">0</span></td><td>—</td><td><span class="pill pr">Paused</span></td></tr>
          <tr><td>Message Leads (UK)</td><td>Apr 26</td><td>$0</td><td>0</td><td>8</td><td>—</td><td><span class="pill pg">1</span></td><td>$0</td><td><span class="pill pa">Residual</span></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 4: ENGAGEMENT -->
  <section class="block">
    <div class="bt">Engagement Campaign Performance</div>
    <div class="bs">Sponsored Update engagement campaigns ran consistently across UK, US and UAE — building brand awareness and warming the LinkedIn audience for future conversion</div>
    <div class="g3">
      <div class="cc">
        <div class="cl">Engagement Campaign Spend ($)</div>
        <div class="cw h200"><canvas id="engSpend"></canvas></div>
      </div>
      <div class="cc">
        <div class="cl">Clicks — Engagement Campaigns</div>
        <div class="cw h200"><canvas id="engClicks"></canvas></div>
      </div>
      <div class="cc">
        <div class="cl">Engagements MoM</div>
        <div class="cw h200"><canvas id="engTotal"></canvas></div>
      </div>
    </div>
  </section>

  <hr class="div">

  <!-- INSIGHTS -->
  <section class="block">
    <div class="bt">Key Narrative — What the LinkedIn Data Tells Us</div>
    <div class="bs">Strategic interpretation of 5 months of LinkedIn campaign performance</div>
    <div class="ig">
      <div class="ic" style="border-left:4px solid #0A3B6E">
        <div class="il" style="color:#0A3B6E">📬 Message open rates are exceptional</div>
        <div class="ib">52–54% open rates on message campaigns far exceed the LinkedIn industry average of 35%. The targeting is reaching the right people — they're reading the messages. The issue is the message-to-CTA conversion, not the audience or reach.</div>
      </div>
      <div class="ic" style="border-left:4px solid var(--red)">
        <div class="il" style="color:var(--red)">🔴 Zero leads from Mar message campaigns despite 1,349 opens</div>
        <div class="ib">March's message campaigns sent 2,502 messages, 1,349 were opened, zero led to a lead form completion. The CTA — likely asking for a direct demo booking from a cold touch — is too much friction. Softer CTAs (case study link, short video, 10-min call vs 30-min demo) need to be tested.</div>
      </div>
      <div class="ic" style="border-left:4px solid var(--accent)">
        <div class="il" style="color:var(--accent)">✅ Engagement campaigns are building the right audience</div>
        <div class="ib">3,041 total clicks and 9,350 engagements over 5 months means a growing pool of LinkedIn users who have interacted with VerbaFlo content. This audience needs to be retargeted with lead gen campaigns — the warm pool exists, it just hasn't been monetised yet.</div>
      </div>
      <div class="ic" style="border-left:4px solid var(--amber)">
        <div class="il" style="color:var(--amber)">📈 CPM is rising — needs monitoring</div>
        <div class="ib">CPM went from $10.96 in December to $95.56 in April — nearly 9× increase. LinkedIn CPMs are naturally higher for B2B targeting but this trajectory signals audience fatigue and creative repetition. Fresh ad creative and new audience segments are critical for May.</div>
      </div>
      <div class="ic" style="border-left:4px solid var(--blue)">
        <div class="il" style="color:var(--blue)">🎯 April ICP Retargeting campaign is the most promising signal</div>
        <div class="ib">The April Lead Gen_RM_All Countries campaign targeting ICP company lists spent $605 and got 1 conversion at $604 CPL — expensive but it's the first time LinkedIn has been used with precise account-based targeting. With a refined message and lower-friction CTA this format has real potential in May.</div>
      </div>
      <div class="ic" style="border-left:4px solid var(--teal)">
        <div class="il" style="color:var(--teal)">⏳ LinkedIn is a 90-day channel — not a 30-day one</div>
        <div class="ib">LinkedIn B2B conversion cycles are longer than Meta or Google. The engagement pool being built now — 9,350 total engagements and growing — will mature into pipeline over Q2–Q3 2026. The strategy should shift to nurture + retarget rather than cold-to-lead in a single touchpoint.</div>
      </div>
    </div>
  </section>

</div>

<footer>
  <div class="fl">Verba<span>Flo</span></div>
  <span>LinkedIn Ads Performance Report · Dec 2025 – Apr 2026</span>
  <span>Confidential</span>
</footer>

<script>
const months=['Dec 25','Jan 26','Feb 26','Mar 26','Apr 26'];
const gc='rgba(128,128,128,0.07)';
const base=(ylabel)=>({responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',titleFont:{size:11},bodyFont:{size:11},padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{title:{display:true,text:ylabel,font:{size:10}},ticks:{font:{size:10}},grid:{color:gc}}}});

new Chart(document.getElementById('spendLine'),{type:'line',data:{labels:months,datasets:[{label:'Spend ($)',data:[434,961,1751,1643,958],borderColor:'#0A3B6E',backgroundColor:'rgba(10,59,110,0.08)',borderWidth:2.5,fill:true,tension:0.4,pointRadius:5,pointHoverRadius:7}]},options:base('Spend ($)')});

new Chart(document.getElementById('impEng'),{type:'bar',data:{labels:months,datasets:[{label:'Impressions',data:[39657,50103,23079,29068,10022],backgroundColor:'rgba(24,95,165,0.7)',yAxisID:'y'},{label:'Engagements',type:'line',data:[361,1816,2237,3138,238],borderColor:'#C8922A',backgroundColor:'transparent',pointRadius:5,borderWidth:2,yAxisID:'y2'}]},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{position:'left',ticks:{font:{size:10}},grid:{color:gc}},y2:{position:'right',ticks:{font:{size:10}},grid:{display:false}}}}});

new Chart(document.getElementById('typeStack'),{type:'bar',data:{labels:months,datasets:[{label:'Engagement/Traffic',data:[434,618,1295,1289,958],backgroundColor:'rgba(27,77,62,0.85)'},{label:'Message/Lead',data:[0,343,456,354,0],backgroundColor:'rgba(24,95,165,0.85)'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{stacked:true,ticks:{font:{size:10}},grid:{display:false}},y:{stacked:true,ticks:{callback:v=>'$'+v,font:{size:10}},grid:{color:gc}}}}});

new Chart(document.getElementById('cpmLine'),{type:'line',data:{labels:months,datasets:[{label:'CPM ($)',data:[10.96,19.19,75.87,56.52,95.56],borderColor:'#BA7517',backgroundColor:'rgba(186,117,23,0.08)',borderWidth:2,fill:true,tension:0.4,pointRadius:5}]},options:{...base('CPM ($)'),plugins:{...base().plugins,tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6,callbacks:{label:c=>`CPM: $${c.parsed.y}`}}}}});

new Chart(document.getElementById('msgBar'),{type:'bar',data:{labels:['Jan 26','Feb 26','Mar 26'],datasets:[{label:'Sends',data:[4345,1105,2502],backgroundColor:'rgba(27,77,62,0.8)'},{label:'Opens',data:[1107,805,1349],backgroundColor:'rgba(200,146,42,0.8)'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}},grid:{color:gc}}}}});

new Chart(document.getElementById('openRate'),{type:'line',data:{labels:['Jan 26','Feb 26','Mar 26'],datasets:[{label:'Open Rate %',data:[25.5,52.0,53.9],borderColor:'#1B4D3E',backgroundColor:'rgba(27,77,62,0.08)',borderWidth:2,fill:true,tension:0.4,pointRadius:6,pointHoverRadius:8}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6,callbacks:{label:c=>`Open rate: ${c.parsed.y}%`}}},scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{ticks:{callback:v=>v+'%',font:{size:10}},title:{display:true,text:'Open Rate %',font:{size:10}},grid:{color:gc}}}}});

new Chart(document.getElementById('engSpend'),{type:'line',data:{labels:months,datasets:[{label:'Eng. Spend',data:[434,618,1295,1289,958],borderColor:'#0A3B6E',backgroundColor:'rgba(10,59,110,0.08)',borderWidth:2,fill:true,tension:0.4,pointRadius:4}]},options:base('$')});

new Chart(document.getElementById('engClicks'),{type:'bar',data:{labels:months,datasets:[{label:'Clicks',data:[358,509,1005,1061,108],backgroundColor:'rgba(24,95,165,0.75)',borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}},grid:{color:gc}}}}});

new Chart(document.getElementById('engTotal'),{type:'bar',data:{labels:months,datasets:[{label:'Engagements',data:[361,510,1104,1152,218],backgroundColor:['rgba(27,77,62,0.4)','rgba(27,77,62,0.55)','rgba(27,77,62,0.7)','rgba(27,77,62,0.85)','rgba(27,77,62,1)'],borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}},grid:{color:gc}}}}});
</script>
</body>
</html>

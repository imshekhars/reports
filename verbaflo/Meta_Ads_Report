<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VerbaFlo — Meta Ads Performance Report | Jan–Apr 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#0D0F0C;--paper:#F5F3EE;--paper-dark:#EAE7E0;
  --accent:#1B4D3E;--al:rgba(27,77,62,0.1);
  --gold:#C8922A;--blue:#185FA5;--red:#C0392B;--purple:#534AB7;--amber:#BA7517;--teal:#0F6E56;
  --text:#1A1C19;--muted:#6B6D68;--light:#9B9D98;--border:rgba(0,0,0,0.07);
}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--text);line-height:1.6}
header{background:linear-gradient(135deg,#1B4D3E 0%,#0F3028 100%);padding:40px 48px;position:relative;overflow:hidden}
header::after{content:'';position:absolute;right:-80px;top:-80px;width:360px;height:360px;border-radius:50%;background:rgba(200,146,42,0.12)}
.header-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1}
.header-label{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,0.45);margin-bottom:8px}
header h1{font-family:'Fraunces',serif;font-size:32px;font-weight:800;color:white;letter-spacing:-1px;line-height:1.1;margin-bottom:6px}
header p{font-size:14px;color:rgba(255,255,255,0.55);font-weight:300}
.platform-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:5px 14px;font-size:12px;color:rgba(255,255,255,0.8);margin-top:14px}
.container{max-width:1200px;margin:0 auto;padding:40px 48px}
.summary-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:40px}
.stat-card{background:white;border:1px solid var(--border);border-radius:12px;padding:16px 18px}
.stat-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--light);margin-bottom:4px}
.stat-val{font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--ink);line-height:1}
.stat-sub{font-size:11px;margin-top:3px}
.up{color:#3B6D11}.dn{color:var(--red)}.neu{color:var(--muted)}
.block{margin-bottom:48px}
.block-title{font-family:'Fraunces',serif;font-size:18px;font-weight:700;color:var(--ink);letter-spacing:-0.3px;margin-bottom:4px}
.block-sub{font-size:13px;color:var(--muted);margin-bottom:20px;font-weight:300}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
.chart-card{background:white;border:1px solid var(--border);border-radius:12px;padding:24px}
.chart-card.full{grid-column:1/-1}
.chart-label{font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:12px}
.chart-wrap{position:relative;width:100%}
.h280{height:280px}.h220{height:220px}.h200{height:200px}
.leg-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:10px}
.leg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.ld{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.table-wrap{background:white;border:1px solid var(--border);border-radius:12px;overflow:hidden}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{background:var(--accent)}
thead th{color:white;padding:10px 14px;text-align:left;font-size:11px;font-weight:500}
tbody tr:nth-child(even){background:#F9F9F8}
tbody tr:hover{background:var(--al)}
tbody td{padding:9px 14px;border-bottom:1px solid var(--border);color:var(--text)}
.pill{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:500}
.pg{background:#E8F5E9;color:#2E7D32}.pr{background:#FFEBEE;color:#C62828}.pa{background:#FFF8E1;color:#F57F17}.pb{background:#E3F2FD;color:#1565C0}
.insight-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:20px}
.insight-card{background:white;border:1px solid var(--border);border-radius:12px;padding:20px 22px}
.ins-label{font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.ins-body{font-size:13px;color:var(--muted);line-height:1.6;font-weight:300}
hr.div{border:none;border-top:1px solid var(--border);margin:40px 0}
footer{background:var(--ink);padding:24px 48px;display:flex;justify-content:space-between;align-items:center;flex-wrap:gap}
footer span{font-size:12px;color:rgba(255,255,255,0.3)}
.footer-logo{font-family:'Fraunces',serif;font-weight:700;font-size:16px;color:white}
.footer-logo span{color:var(--gold)}
@media(max-width:900px){
  .summary-grid,.g2,.g3,.insight-grid{grid-template-columns:1fr 1fr}
  .container,.header{padding:24px}
  header{padding:28px 24px}
}
@media(max-width:600px){
  .summary-grid,.insight-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="header-label">Performance Report</div>
    <h1>VerbaFlo — Meta Ads Analysis</h1>
    <p>January 2026 — April 2026 &nbsp;·&nbsp; UK, US, UAE markets &nbsp;·&nbsp; Lead Gen, Traffic, Awareness</p>
    <div class="platform-badge">📱 Meta — Facebook & Instagram</div>
  </div>
</header>

<div class="container">

  <div class="summary-grid" style="margin-top:32px">
    <div class="stat-card">
      <div class="stat-label">Total spend</div>
      <div class="stat-val">£10,875</div>
      <div class="stat-sub neu">Jan–Apr 2026</div>
    </div>
    <div class="stat-card">
      <div class="stat-val">661k+</div>
      <div class="stat-label">Total impressions</div>
      <div class="stat-sub up">↑ Scaling month on month</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total reach</div>
      <div class="stat-val">385k+</div>
      <div class="stat-sub neu">Unique people reached</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total leads</div>
      <div class="stat-val">137</div>
      <div class="stat-sub up">↑ 51 leads in April alone</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Best CPL</div>
      <div class="stat-val">£13.23</div>
      <div class="stat-sub up">↑ IF US — Jan 2026</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avg CPL (Apr)</div>
      <div class="stat-val">£86.7</div>
      <div class="stat-sub neu">Incl. all lead campaigns</div>
    </div>
  </div>

  <!-- SECTION 1: OVERALL -->
  <section class="block">
    <div class="block-title">Overall Monthly Performance Trends</div>
    <div class="block-sub">Total spend, impressions, reach and leads — January to April 2026</div>
    <div class="g2">
      <div class="chart-card">
        <div class="chart-label">Monthly Spend (£)</div>
        <div class="chart-wrap h280"><canvas id="spendLine"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="leg-row">
          <div class="leg"><span class="ld" style="background:#185FA5"></span>Impressions</div>
          <div class="leg"><span class="ld" style="background:#C8922A"></span>Reach</div>
        </div>
        <div class="chart-label">Impressions vs Reach</div>
        <div class="chart-wrap h280"><canvas id="impReach"></canvas></div>
      </div>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 2: LEADS -->
  <section class="block">
    <div class="block-title">Lead Generation Performance</div>
    <div class="block-sub">Leads generated, CPL trends and campaign type breakdown — Instant Form consistently outperformed all other formats</div>
    <div class="g2">
      <div class="chart-card">
        <div class="leg-row">
          <div class="leg"><span class="ld" style="background:#1B4D3E"></span>IF UK</div>
          <div class="leg"><span class="ld" style="background:#185FA5"></span>IF US</div>
          <div class="leg"><span class="ld" style="background:#0F6E56"></span>IF UAE</div>
          <div class="leg"><span class="ld" style="background:#534AB7"></span>LP Leads</div>
          <div class="leg"><span class="ld" style="background:#BA7517"></span>Remarketing</div>
        </div>
        <div class="chart-label">Leads by Campaign Type — Monthly</div>
        <div class="chart-wrap h280"><canvas id="leadsBar"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="leg-row">
          <div class="leg"><span class="ld" style="background:#1B4D3E"></span>IF UK CPL</div>
          <div class="leg"><span class="ld" style="background:#185FA5"></span>IF US CPL</div>
          <div class="leg"><span class="ld" style="background:#0F6E56"></span>IF UAE CPL</div>
        </div>
        <div class="chart-label">CPL Trend — Instant Form Campaigns (£)</div>
        <div class="chart-wrap h280"><canvas id="cplLine"></canvas></div>
      </div>
    </div>

    <div class="table-wrap" style="margin-top:20px">
      <table>
        <thead><tr><th>Campaign</th><th>Market</th><th>Jan 26</th><th>Feb 26</th><th>Mar 26</th><th>Apr 26</th><th>Total Leads</th><th>Best CPL</th></tr></thead>
        <tbody>
          <tr><td><strong>Instant Form</strong></td><td>US</td><td>8 leads · £13</td><td>19 leads · £39</td><td>12 leads · £95</td><td>24 leads · £80</td><td><span class="pill pg">63</span></td><td>£13.23</td></tr>
          <tr><td><strong>Instant Form</strong></td><td>UK</td><td>—</td><td>7 leads · £70</td><td>27 leads · £39</td><td>10 leads · £126</td><td><span class="pill pg">44</span></td><td>£38.80</td></tr>
          <tr><td><strong>Instant Form</strong></td><td>UAE</td><td>—</td><td>—</td><td>—</td><td>12 leads · £40</td><td><span class="pill pb">12</span></td><td>£40.37</td></tr>
          <tr><td><strong>Remarketing</strong></td><td>UK</td><td>—</td><td>—</td><td>4 leads · £106</td><td>—</td><td><span class="pill pa">4</span></td><td>£105.77</td></tr>
          <tr><td><strong>Landing Page</strong></td><td>UK</td><td>—</td><td>2 leads · £74</td><td>3 leads · £67</td><td>—</td><td><span class="pill pa">5</span></td><td>£67.21</td></tr>
          <tr><td><strong>Landing Page</strong></td><td>US</td><td>—</td><td>0 leads</td><td>0 leads</td><td>—</td><td><span class="pill pr">0</span></td><td>— Paused</td></tr>
          <tr><td><strong>Sales Page View</strong></td><td>US + UK</td><td>—</td><td>0 leads</td><td>0 leads</td><td>—</td><td><span class="pill pr">0</span></td><td>— Paused</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 3: CAMPAIGN MIX -->
  <section class="block">
    <div class="block-title">Campaign Spend Mix</div>
    <div class="block-sub">How budget evolved across campaign types — from traffic-heavy in Feb to Instant Form dominant by April</div>
    <div class="g2">
      <div class="chart-card full">
        <div class="leg-row">
          <div class="leg"><span class="ld" style="background:#1B4D3E"></span>Instant Form</div>
          <div class="leg"><span class="ld" style="background:#185FA5"></span>Traffic/Page View</div>
          <div class="leg"><span class="ld" style="background:#534AB7"></span>LP Lead</div>
          <div class="leg"><span class="ld" style="background:#C0392B"></span>Sales Page View</div>
          <div class="leg"><span class="ld" style="background:#0F6E56"></span>Awareness/Reach</div>
          <div class="leg"><span class="ld" style="background:#BA7517"></span>Remarketing</div>
        </div>
        <div class="chart-label">Campaign Spend Mix — Stacked (£)</div>
        <div class="chart-wrap h280"><canvas id="campStack"></canvas></div>
      </div>
    </div>

    <div class="g3" style="margin-top:20px">
      <div class="chart-card">
        <div class="chart-label">Instant Form Spend Growth</div>
        <div class="chart-wrap h200"><canvas id="ifGrowth"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-label">CPM Trend (£)</div>
        <div class="chart-wrap h200"><canvas id="cpmTrend"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-label">Total Leads Month on Month</div>
        <div class="chart-wrap h200"><canvas id="totalLeads"></canvas></div>
      </div>
    </div>
  </section>

  <hr class="div">

  <!-- SECTION 4: REACH -->
  <section class="block">
    <div class="block-title">Reach & Awareness Growth</div>
    <div class="block-sub">Total unique people reached and impression frequency — showing brand exposure building over time</div>
    <div class="g2">
      <div class="chart-card">
        <div class="chart-label">Monthly Reach by Market (estimated)</div>
        <div class="chart-wrap h280"><canvas id="reachMarket"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="leg-row">
          <div class="leg"><span class="ld" style="background:#185FA5"></span>Total impressions</div>
          <div class="leg"><span class="ld" style="background:#C8922A;height:3px;border-radius:2px;width:16px"></span>Total reach</div>
        </div>
        <div class="chart-label">Impressions vs Unique Reach — scale of exposure</div>
        <div class="chart-wrap h280"><canvas id="impReach2"></canvas></div>
      </div>
    </div>
  </section>

  <hr class="div">

  <!-- KEY INSIGHTS -->
  <section class="block">
    <div class="block-title">Key Narrative — What the Data Tells Us</div>
    <div class="block-sub">Strategic interpretation of 4 months of Meta campaign performance</div>
    <div class="insight-grid">
      <div class="insight-card" style="border-left:4px solid var(--accent)">
        <div class="ins-label" style="color:var(--accent)">📈 Instant Form is the winning format</div>
        <div class="ins-body">Instant Form campaigns generated 119 of 137 total leads (87%). By keeping users in-platform and removing the landing page friction, CPL on UK Instant Form dropped to £38.80 in March — the most efficient lead generation month across both markets.</div>
      </div>
      <div class="insight-card" style="border-left:4px solid var(--red)">
        <div class="ins-label" style="color:var(--red)">🚫 Landing page & sales page formats paused correctly</div>
        <div class="ins-body">Landing Page (US) and Sales Page View campaigns consumed £869 combined across Feb–Mar and generated 0 leads. The correct decision was made to pause these. Meta audiences don't convert on external landing pages the same way search traffic does — the Instant Form insight proved this conclusively.</div>
      </div>
      <div class="insight-card" style="border-left:4px solid var(--blue)">
        <div class="ins-label" style="color:var(--blue)">🌍 UAE is an early but efficient market</div>
        <div class="ins-body">UAE was only launched in April 2026 but generated 12 leads at £40.37 CPL — the second-lowest CPL in the account. At £484 spend with strong CTR (0.46%) and reach of 12,140, UAE signals a high-quality audience worth scaling in May with increased budget.</div>
      </div>
      <div class="insight-card" style="border-left:4px solid var(--amber)">
        <div class="ins-label" style="color:var(--amber)">⚠️ April CPM spike needs monitoring</div>
        <div class="ins-body">CPM jumped from £12.8 in March to £32.4 in April — a 153% increase. This indicates audience saturation on core interest stacks, particularly US. As flagged in-month, Advantage+ broad audience targeting and new creative rotation must be maintained to prevent further CPM inflation in May.</div>
      </div>
      <div class="insight-card" style="border-left:4px solid var(--teal)">
        <div class="ins-label" style="color:var(--teal)">✅ Remarketing is validated — needs scale</div>
        <div class="ins-body">The March remarketing campaign generated 4 leads at £105 CPL — expensive but expected for a brand-new, small remarketing pool. As overall traffic and website visitors grow month on month, the remarketing pool will deepen and CPL will fall significantly. This channel should be a priority in May.</div>
      </div>
      <div class="insight-card" style="border-left:4px solid var(--purple)">
        <div class="ins-label" style="color:var(--purple)">📊 Total leads doubled Feb→Mar→Apr</div>
        <div class="ins-body">From 28 leads in February to 50 in March to 51 in April — a near-doubling in just 2 months despite CPM rising. This demonstrates that the Instant Form format, combined with fresh creative and Advantage+ audience expansion, is able to maintain lead velocity even under audience pressure.</div>
      </div>
    </div>
  </section>

</div>

<footer>
  <div class="footer-logo">Verba<span>Flo</span></div>
  <span>Meta Ads Performance Report · Jan–Apr 2026</span>
  <span>Confidential</span>
</footer>

<script>
const months = ['Jan 26','Feb 26','Mar 26','Apr 26'];
const gc = 'rgba(128,128,128,0.07)';
const baseOpts = (ylabel) => ({
  responsive:true, maintainAspectRatio:false,
  interaction:{mode:'index',intersect:false},
  plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',titleFont:{size:11},bodyFont:{size:11},padding:10,cornerRadius:6}},
  scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{title:{display:true,text:ylabel,font:{size:10}},ticks:{font:{size:10}},grid:{color:gc}}}
});

// 1. Spend line
new Chart(document.getElementById('spendLine'),{type:'line',data:{labels:months,datasets:[{label:'Spend (£)',data:[222,2269,3964,4420],borderColor:'#1B4D3E',backgroundColor:'rgba(27,77,62,0.08)',borderWidth:2.5,fill:true,tension:0.4,pointRadius:5,pointHoverRadius:7}]},options:baseOpts('Spend (£)')});

// 2. Impressions vs Reach
new Chart(document.getElementById('impReach'),{type:'bar',data:{labels:months,datasets:[
  {label:'Impressions',data:[14670,200515,309570,136513],backgroundColor:'rgba(24,95,165,0.7)',yAxisID:'y'},
  {label:'Reach',type:'line',data:[12514,153597,190093,29099],borderColor:'#C8922A',backgroundColor:'transparent',pointRadius:5,borderWidth:2,yAxisID:'y2'}
]},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{position:'left',ticks:{font:{size:10}},grid:{color:gc}},y2:{position:'right',ticks:{font:{size:10}},grid:{display:false}}}}});

// 3. Leads by type stacked
new Chart(document.getElementById('leadsBar'),{type:'bar',data:{labels:months,datasets:[
  {label:'IF UK',data:[0,7,27,10],backgroundColor:'rgba(27,77,62,0.85)'},
  {label:'IF US',data:[8,19,12,24],backgroundColor:'rgba(24,95,165,0.85)'},
  {label:'IF UAE',data:[0,0,0,12],backgroundColor:'rgba(15,110,86,0.85)'},
  {label:'LP UK',data:[0,2,3,0],backgroundColor:'rgba(83,74,183,0.85)'},
  {label:'Remarketing',data:[0,0,4,0],backgroundColor:'rgba(186,117,23,0.85)'},
]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{stacked:true,ticks:{font:{size:10}},grid:{display:false}},y:{stacked:true,ticks:{font:{size:10}},grid:{color:gc}}}}});

// 4. CPL line
new Chart(document.getElementById('cplLine'),{type:'line',data:{labels:months,datasets:[
  {label:'IF UK CPL',data:[null,70.09,38.80,125.55],borderColor:'#1B4D3E',borderWidth:2,tension:0.4,pointRadius:5,backgroundColor:'transparent',spanGaps:true},
  {label:'IF US CPL',data:[13.23,38.55,95.15,80.08],borderColor:'#185FA5',borderWidth:2,tension:0.4,pointRadius:5,backgroundColor:'transparent'},
  {label:'IF UAE CPL',data:[null,null,null,40.37],borderColor:'#0F6E56',borderWidth:2,tension:0.4,pointRadius:5,backgroundColor:'transparent',spanGaps:true},
]},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6,callbacks:{label:c=>`${c.dataset.label}: £${c.parsed.y||'—'}`}}},scales:{x:{ticks:{font:{size:10}},grid:{color:gc}},y:{title:{display:true,text:'CPL (£)',font:{size:10}},ticks:{callback:v=>'£'+v,font:{size:10}},grid:{color:gc}}}}});

// 5. Campaign spend stack
new Chart(document.getElementById('campStack'),{type:'bar',data:{labels:months,datasets:[
  {label:'Instant Form',data:[164,1223,2613,4352],backgroundColor:'rgba(27,77,62,0.85)'},
  {label:'Traffic/Page View',data:[58,537,218,68],backgroundColor:'rgba(24,95,165,0.85)'},
  {label:'Landing Page Lead',data:[0,297,315,0],backgroundColor:'rgba(83,74,183,0.85)'},
  {label:'Sales Page View',data:[0,211,190,0],backgroundColor:'rgba(192,57,43,0.85)'},
  {label:'Awareness/Reach',data:[0,0,205,0],backgroundColor:'rgba(15,110,86,0.85)'},
  {label:'Remarketing',data:[0,0,423,0],backgroundColor:'rgba(186,117,23,0.85)'},
]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1C19',padding:10,cornerRadius:6}},scales:{x:{stacked:true,ticks:{font:{size:10}},grid:{display:false}},y:{stacked:true,ticks:{callback:v=>'£'+v,font:{size:10}},grid:{color:gc}}}}});

// 6. IF spend growth
new Chart(document.getElementById('ifGrowth'),{type:'line',data:{labels:months,datasets:[{label:'IF Spend',data:[164,1223,2613,4352],borderColor:'#1B4D3E',backgroundColor:'rgba(27,77,62,0.08)',borderWidth:2,fill:true,tension:0.4,pointRadius:4}]},options:baseOpts('£')});

// 7. CPM trend
